# ─── Zell Frontend Environment ───────────────────────────────────────────────
#
# Copy this file to .env (or .env.local) and customise for your deployment.
#
# API base URL — where your backend is running.
# In development (same machine), leave this unset and the frontend will use
# window.location.hostname:8000 automatically.
#
# For production, set this to your actual API URL:
# VITE_API_BASE=https://api.yourdomain.com
